<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_attendance_user_tree" model="ir.ui.view">
        <field name="name">iot.attendance.user.tree</field>
        <field name="model">iot.attendance.user</field>
        <field name="arch" type="xml">
            <list>
                <field name="device_id"/>
                <field name="employee_id"/>
                <field name="device_user_id"/>
                <field name="device_uid"/>
                <field name="last_seen_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_iot_attendance_user_form" model="ir.ui.view">
        <field name="name">iot.attendance.user.form</field>
        <field name="model">iot.attendance.user</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="device_id"/>
                            <field name="employee_id"/>
                            <field name="device_user_id"/>
                        </group>
                        <group>
                            <field name="device_uid"/>
                            <field name="last_seen_at" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iot_attendance_user" model="ir.actions.act_window">
        <field name="name">Attendance Mappings</field>
        <field name="res_model">iot.attendance.user</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_iot_attendance_user" name="Mappings" parent="menu_iot_attendance_root" action="action_iot_attendance_user" sequence="20" groups="base.group_erp_manager"/>
</odoo>
