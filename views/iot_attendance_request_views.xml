<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_attendance_request_tree" model="ir.ui.view">
        <field name="name">iot.attendance.request.tree</field>
        <field name="model">iot.attendance.request</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="create_date"/>
                <field name="endpoint"/>
                <field name="method"/>
                <field name="serial_number"/>
                <field name="remote_ip"/>
                <field name="device_id"/>
                <field name="status"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_iot_attendance_request_form" model="ir.ui.view">
        <field name="name">iot.attendance.request.form</field>
        <field name="model">iot.attendance.request</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="endpoint"/>
                            <field name="method"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="device_id"/>
                            <field name="serial_number"/>
                            <field name="remote_ip"/>
                            <field name="note"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload_text" widget="text"/>
                        </page>
                        <page string="Query Params">
                            <field name="query_params" widget="text"/>
                        </page>
                        <page string="Headers">
                            <field name="headers" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iot_attendance_request" model="ir.actions.act_window">
        <field name="name">Attendance Request Logs</field>
        <field name="res_model">iot.attendance.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
    </record>

    <menuitem id="menu_iot_attendance_request" name="Request Logs" parent="menu_iot_attendance_root" action="action_iot_attendance_request" sequence="40" groups="base.group_erp_manager"/>
</odoo>
