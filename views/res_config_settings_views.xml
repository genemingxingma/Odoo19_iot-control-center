<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_iot_control_center" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.iot.control.center</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="IoT Control Center" name="iot_control_center" groups="base.group_system">
                    <block title="External IoT Middleware">
                        <setting string="Use External IoT Middleware (MQTT + TH TCP)">
                            <field name="iot_middleware_enabled"/>
                            <div class="text-muted">
                                Enable this to route both MQTT relay traffic and Temperature/Humidity TCP gateway traffic through middleware.
                            </div>
                        </setting>
                        <setting string="Middleware Base URL">
                            <field name="iot_middleware_base_url" placeholder="http://127.0.0.1:8099"/>
                        </setting>
                        <setting string="Middleware Token">
                            <field name="iot_middleware_token" password="True"/>
                            <div class="text-muted">
                                Must exactly match the IOT_BRIDGE_TOKEN value in middleware environment config.
                            </div>
                        </setting>
                    </block>
                    <block title="OpenWrt AC">
                        <setting string="OpenWrt Online Timeout (sec)">
                            <field name="iot_openwrt_online_timeout_sec"/>
                        </setting>
                        <setting string="Heartbeat Interval (sec)">
                            <field name="iot_openwrt_heartbeat_interval_sec"/>
                            <div class="text-muted">
                                Middleware checks AP reachability on this interval.
                            </div>
                        </setting>
                        <setting string="Full Probe Every N Heartbeats">
                            <field name="iot_openwrt_full_probe_every"/>
                            <div class="text-muted">
                                A full OpenWrt probe runs every N heartbeat cycles to refresh version and hardware facts.
                            </div>
                        </setting>
                        <setting string="Offline Failure Threshold">
                            <field name="iot_openwrt_offline_failure_threshold"/>
                            <div class="text-muted">
                                After this many consecutive heartbeat failures, the AP is marked offline.
                            </div>
                        </setting>
                        <setting string="Generate OpenWrt SSH Key">
                            <div class="content-group">
                                <button name="action_generate_openwrt_ssh_key" type="object" string="Generate / Refresh SSH Key" class="btn btn-primary"/>
                            </div>
                            <div class="text-muted">
                                Generate one SSH key pair for OpenWrt AP management. Add the public key manually to each AP's authorized_keys file.
                            </div>
                        </setting>
                        <setting string="OpenWrt SSH Private Key Path">
                            <field name="iot_openwrt_ssh_private_key_path" readonly="1"/>
                        </setting>
                        <setting string="OpenWrt SSH Public Key">
                            <field name="iot_openwrt_ssh_public_key" readonly="1"/>
                            <div class="text-muted">
                                Add this public key manually to each OpenWrt AP's authorized_keys file, then bind the AP in IoT Control Center.
                            </div>
                        </setting>
                    </block>
                    <block title="MQTT Broker">
                        <setting string="MQTT Host">
                            <field name="iot_mqtt_host" placeholder="iot.imytest.com"/>
                        </setting>
                        <setting string="MQTT Port">
                            <field name="iot_mqtt_port"/>
                        </setting>
                        <setting string="MQTT Username">
                            <field name="iot_mqtt_username"/>
                        </setting>
                        <setting string="MQTT Password">
                            <field name="iot_mqtt_password" password="True"/>
                        </setting>
                        <setting string="Topic Root">
                            <field name="iot_mqtt_topic_root"/>
                        </setting>
                        <setting string="MQTT Keepalive (sec)">
                            <field name="iot_mqtt_keepalive"/>
                        </setting>
                        <setting string="MQTT Message Retention (days)">
                            <field name="iot_mqtt_message_retention_days"/>
                        </setting>
                        <setting string="Unbound Device Retention (days)">
                            <field name="iot_device_retention_days"/>
                        </setting>
                        <setting string="Online Timeout (sec)">
                            <field name="iot_online_timeout_sec"/>
                        </setting>
                        <setting string="Firmware Base URL">
                            <field name="iot_firmware_base_url" placeholder="iot.imytest.com"/>
                        </setting>
                    </block>
                    <block title="Temperature/Humidity TCP Ingest">
                        <setting string="TCP Listen Host">
                            <field name="iot_th_tcp_host" placeholder="0.0.0.0"/>
                        </setting>
                        <setting string="TCP Listen Port">
                            <field name="iot_th_tcp_port"/>
                        </setting>
                        <setting string="TH Online Timeout (sec)">
                            <field name="iot_th_online_timeout_sec"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
