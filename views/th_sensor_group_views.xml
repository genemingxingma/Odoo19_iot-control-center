<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_th_sensor_group_list" model="ir.ui.view">
        <field name="name">iot.th.sensor.group.list</field>
        <field name="model">iot.th.sensor.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="sensor_count"/>
                <field name="temperature_low"/>
                <field name="temperature_high"/>
                <field name="humidity_low"/>
                <field name="humidity_high"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_iot_th_sensor_group_form" model="ir.ui.view">
        <field name="name">iot.th.sensor.group.form</field>
        <field name="model">iot.th.sensor.group</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_sensors" type="object" string="Open Sensors"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="sensor_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="temperature_low"/>
                            <field name="temperature_high"/>
                            <field name="humidity_low"/>
                            <field name="humidity_high"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <group string="Sensors in This Group">
                        <field name="sensor_ids" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="node_id"/>
                                <field name="probe_code"/>
                                <field name="company_id"/>
                                <field name="last_temperature"/>
                                <field name="last_humidity"/>
                                <field name="last_reported_at"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iot_th_sensor_group" model="ir.actions.act_window">
        <field name="name">Sensor Groups</field>
        <field name="res_model">iot.th.sensor.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_iot_th_sensor_group" name="Sensor Groups" parent="menu_iot_environment_root" action="action_iot_th_sensor_group" sequence="19" groups="base.group_erp_manager"/>
</odoo>
