<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_iot_attendance_punch_tree" model="ir.ui.view">
        <field name="name">iot.attendance.punch.tree</field>
        <field name="model">iot.attendance.punch</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="punch_time"/>
                <field name="device_id"/>
                <field name="employee_id"/>
                <field name="device_user_id"/>
                <field name="direction"/>
                <field name="source"/>
                <field name="state"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="view_iot_attendance_punch_form" model="ir.ui.view">
        <field name="name">iot.attendance.punch.form</field>
        <field name="model">iot.attendance.punch</field>
        <field name="arch" type="xml">
            <form create="0">
                <sheet>
                    <group>
                        <group>
                            <field name="device_id"/>
                            <field name="employee_id"/>
                            <field name="attendance_id" readonly="1"/>
                            <field name="device_user_id"/>
                            <field name="device_uid"/>
                        </group>
                        <group>
                            <field name="punch_time"/>
                            <field name="direction"/>
                            <field name="source"/>
                            <field name="state"/>
                            <field name="message"/>
                        </group>
                    </group>
                    <group>
                        <field name="raw_payload" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_iot_attendance_punch" model="ir.actions.act_window">
        <field name="name">Attendance Punches</field>
        <field name="res_model">iot.attendance.punch</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_iot_attendance_punch" name="Punch Logs" parent="menu_iot_attendance_root" action="action_iot_attendance_punch" sequence="30" groups="base.group_erp_manager"/>
</odoo>
